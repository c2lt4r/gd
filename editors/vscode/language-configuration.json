{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*#\\s*region\\b",
      "end": "^\\s*#\\s*endregion\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(func|class|class_name|if|elif|else|for|while|match|static|@onready|@export)\\b.*:\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(elif|else|pass|return|break|continue)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(func|class|class_name|if|elif|else|for|while|match)\\b.*:\\s*(#.*)?$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*(pass|return|break|continue)\\b.*$",
      "action": {
        "indent": "outdent"
      }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}
