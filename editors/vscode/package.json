{
  "name": "gd-gdscript",
  "displayName": "GDScript (gd)",
  "description": "GDScript language support powered by the gd toolchain — formatting, linting, go-to-definition, and more",
  "version": "0.1.3",
  "publisher": "c2lt4r",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/c2lt4r/gd"
  },
  "homepage": "https://github.com/c2lt4r/gd",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "godot",
    "gdscript",
    "gamedev",
    "linter",
    "formatter"
  ],
  "activationEvents": [
    "onLanguage:gdscript",
    "workspaceContains:**/*.gd"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gdscript",
        "aliases": [
          "GDScript",
          "gdscript"
        ],
        "extensions": [
          ".gd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gdscript",
        "scopeName": "source.gdscript",
        "path": "./syntaxes/gdscript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "gd.restartLsp",
        "title": "Restart Language Server",
        "category": "GDScript"
      },
      {
        "command": "gd.formatAll",
        "title": "Format All Files",
        "category": "GDScript"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "gd.formatAll",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace"
        }
      ]
    },
    "configuration": {
      "title": "GDScript (gd)",
      "properties": {
        "gd.path": {
          "type": "string",
          "default": "gd",
          "description": "Path to the gd binary"
        },
        "gd.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the gd language server"
        },
        "gd.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the gd language server (for debugging)"
        }
      }
    },
    "configurationDefaults": {
      "[gdscript]": {
        "editor.defaultFormatter": "c2lt4r.gd-gdscript",
        "editor.formatOnSave": true,
        "editor.insertSpaces": false,
        "editor.tabSize": 4,
        "editor.trimAutoWhitespace": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "compile:check": "tsc -p . --noEmit",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production && vsce package --no-dependencies"
  }
}
